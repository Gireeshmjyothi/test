import java.util.*;
import java.util.concurrent.atomic.AtomicLong;
import java.util.stream.Collectors;

public class TreasuryConverter {

    public static List<String> convertToDollarSeparated(List<TreasuryDto> list) {

        AtomicLong counter = new AtomicLong(1000);

        return list.stream()
                .map(dto -> {

                    long uniqueId = counter.getAndIncrement();

                    return String.join("$",
                            String.valueOf(uniqueId),          // unique number
                            safe(dto.getName()),
                            safe(dto.getAccountNumber()),
                            safe(dto.getAmount())
                    );
                })
                .collect(Collectors.toList());
    }

    private static String safe(Object value) {
        return value == null ? "" : String.valueOf(value);
    }
}
