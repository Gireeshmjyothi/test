import java.io.BufferedWriter;
import java.io.IOException;
import java.nio.file.Files;
import java.nio.file.Path;
import java.math.BigDecimal;
import java.util.List;
import java.util.concurrent.atomic.AtomicLong;

public class TreasuryFileWriter {

    public static void writeToFile(List<TreasuryDto> list, String filePath) throws IOException {

        AtomicLong counter = new AtomicLong(1000);

        try (BufferedWriter writer = Files.newBufferedWriter(Path.of(filePath))) {

            for (TreasuryDto dto : list) {

                if (dto == null) {
                    writer.newLine();
                    continue;
                }

                long uniqueId = counter.getAndIncrement();

                String line = String.join("$",

                        // ✅ Unique ID
                        String.valueOf(uniqueId),

                        // ✅ Fields from your DTO
                        safe(dto.getBscrRecordId()),
                        safe(dto.getMultiTransfer()),
                        safe(dto.getMscrRecordId()),
                        safe(dto.getBankName()),
                        safe(dto.getBankCode()),
                        safe(dto.getBranchCode()),
                        safe(dto.getBankCin()),

                        safe(dto.getMainScrollDate()),
                        safe(dto.getMainScrollNumber()),
                        safe(dto.getNoOfSubScrolls()),
                        safe(dto.getTotalMainScrollAmount()),
                        safe(dto.getSscrRecordId()),

                        safe(dto.getScrollNumber()),

                        safe(dto.getSubScrollDate()),
                        safe(dto.getSubScrollNumber()),
                        safe(dto.getNoOfChallans()),
                        safe(dto.getTotalSubScrollAmount()),
                        safe(dto.getChlnRecordId()),

                        safe(dto.getOfficeCode()),
                        safe(dto.getFormNo()),
                        safe(dto.getGrn()),
                        safe(dto.getBankAccountCode()),
                        safe(dto.getAmountForBankAccount()),
                        safe(dto.getGovernmentChallanDate()),
                        safe(dto.getPayeeNo()),
                        safe(dto.getPayeeName()),
                        safe(dto.getPeriodFrom()),
                        safe(dto.getPeriodTo()),
                        safe(dto.getStatus()),
                        safe(dto.getTransCompletionDateTime()),
                        safe(dto.getBankPaymentReferenceNumber()),
                        safe(dto.getValRecordId())
                );

                writer.write(line);
                writer.newLine();
            }
        }
    }

    // ✅ Null-safe method (IMPORTANT)
    private static String safe(Object value) {
        if (value == null) return "";

        if (value instanceof BigDecimal) {
            return ((BigDecimal) value).toPlainString(); // avoids scientific notation
        }

        return String.valueOf(value);
    }
}
